<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Pedido" }) %>

<body>
  <%- include('partials/header') %>
  <% const formatearPrecio = valor => new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(Number(valor) || 0); %>

  <div class="w-full max-w-7xl px-6">
    <h1 class="text-4xl font-bold text-center text-blue-800 mb-10 drop-shadow">
      <i data-lucide="shopping-cart"></i> Realizar Pedido
    </h1>

    <form action="/cliente/pedido" method="POST" class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <div class="lg:col-span-3 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">
        <% if (productos.length === 0) { %>
          <p class="text-center text-gray-600 col-span-full">No hay productos disponibles.</p>
        <% } else { %>
          <% productos.forEach(producto => { %>
            <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-2xl transition duration-300 border border-blue-200">
              <h2 class="text-xl font-bold text-blue-800 mb-2"><%= producto.nombre %></h2>
              <p class="text-gray-700 mb-3">
                <i data-lucide="badge-dollar-sign"></i>
                <span class="font-semibold"><%= formatearPrecio(producto.precio) %></span>
              </p>
              <label class="block text-sm text-gray-600">
                Cantidad:
                <input
                  type="number"
                  name="cantidad_<%= producto.id %>"
                  min="0"
                  value="0"
                  class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
                />
              </label>
            </div>
          <% }) %>
        <% } %>
      </div>

      <aside class="bg-white rounded-2xl shadow-lg p-6 border border-blue-200 h-fit">
        <h2 class="text-2xl font-bold text-blue-800 mb-4">
          <i data-lucide="shopping-basket"></i> Mi Carrito
        </h2>
        <p class="text-gray-600 mb-6">Completa los datos de entrega antes de enviar tu pedido.</p>

        <label class="block text-sm text-gray-600 mb-4">
          Direccion de entrega
          <input
            type="text"
            name="direccion_entrega"
            required
            minlength="5"
            maxlength="255"
            placeholder="Ej: Av. Principal 1234"
            class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          />
        </label>

        <label class="block text-sm text-gray-600 mb-4">
          Comuna
          <select
            name="comuna_id"
            required
            class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          >
            <option value="">Selecciona una comuna</option>
            <% comunas.forEach(comuna => { %>
              <option value="<%= comuna.id %>"><%= comuna.nombre %></option>
            <% }) %>
          </select>
        </label>

        <div class="mt-6">
          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-300">
            <i data-lucide="send"></i> Enviar Pedido
          </button>
        </div>
      </aside>
    </form>
  </div>

  <%- include('partials/footer') %>
</body>
</html>

