<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Editar Chofer | MasAgua" }) %>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="admin-hero">
      <div>
        <p class="section-label">Logistica</p>
        <h1>Editar chofer</h1>
        <p class="muted">Mantiene una zona base y comunas coherentes para el reparto.</p>
      </div>
      <a href="/choferes" class="btn btn-secondary"><i data-lucide="arrow-left"></i> Volver</a>
    </section>

    <section class="driver-form-shell">
      <article class="app-card fleet-form-card">
        <form action="/choferes/editar/<%= chofer.id %>" method="POST" class="fleet-form">
          <div class="form-grid">
            <label>Nombre completo<input type="text" name="nombre" value="<%= chofer.nombre %>" required autocomplete="off"></label>
            <label>RUT<input type="text" name="rut" value="<%= chofer.rut %>" required autocomplete="off"></label>
            <label>Telefono<input type="text" name="telefono" value="<%= chofer.telefono || '' %>" autocomplete="off"></label>
            <label>Direccion<input type="text" name="direccion" value="<%= chofer.direccion || '' %>" autocomplete="off"></label>
            <label>Estado<input type="text" name="estado" value="<%= chofer.estado || 'activo' %>" autocomplete="off"></label>
            <label>Vehiculo
              <select name="vehiculo_id">
                <option value="">Sin vehiculo asignado</option>
                <% vehiculos.forEach(v => { %>
                  <option value="<%= v.id %>" <%= Number(chofer.vehiculo_id) === Number(v.id) ? 'selected' : '' %>><%= v.patente %> - <%= v.marca || '' %> <%= v.modelo || '' %></option>
                <% }) %>
              </select>
            </label>
            <label>Zona base
              <select name="zona_id" required data-zone-select>
                <option value="">Selecciona una zona</option>
                <% zonas.forEach(z => { %>
                  <option value="<%= z.id %>" <%= Number(chofer.zona_id) === Number(z.id) ? 'selected' : '' %>><%= z.nombre %></option>
                <% }) %>
              </select>
            </label>
            <label>Comunas de cobertura
              <select name="comunas" multiple required size="9" data-commune-select>
                <% zonas.forEach(z => { %>
                  <% z.comunas.forEach(c => { %>
                    <option value="<%= c.id %>" data-zona="<%= z.id %>" <%= comunasAsignadas.includes(c.id) ? 'selected' : '' %>><%= c.nombre %></option>
                  <% }) %>
                <% }) %>
              </select>
            </label>
          </div>

          <p class="muted form-note">Si cambias la zona base, vuelve a seleccionar las comunas de esa misma zona.</p>

          <div class="form-actions">
            <button type="submit"><i data-lucide="save"></i> Guardar cambios</button>
            <a href="/choferes" class="btn btn-secondary">Cancelar</a>
          </div>
        </form>
      </article>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script>
  document.addEventListener('DOMContentLoaded', function () {
    const zonaSelect = document.querySelector('[data-zone-select]');
    const comunaSelect = document.querySelector('[data-commune-select]');
    if (!zonaSelect || !comunaSelect) return;

    function syncComunas() {
      const zonaId = zonaSelect.value;
      Array.from(comunaSelect.options).forEach(option => {
        const visible = option.dataset.zona === zonaId;
        option.hidden = !visible;
        option.disabled = !visible;
        if (!visible) option.selected = false;
      });
    }

    zonaSelect.addEventListener('change', syncComunas);
    syncComunas();
  });
</script>
</body>
</html>
