<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Choferes | MasAgua" }) %>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="admin-hero">
      <div>
        <p class="section-label">Logistica</p>
        <h1>Choferes</h1>
        <p class="muted">Administra choferes, zona base y comunas de cobertura coherentes.</p>
      </div>
      <a href="/choferes/nuevo" class="btn"><i data-lucide="user-plus"></i> Agregar chofer</a>
    </section>

    <section>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nombre</th>
              <th>RUT</th>
              <th>Telefono</th>
              <th>Zona base</th>
              <th>Comunas</th>
              <th>Vehiculo</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (!choferes || choferes.length === 0) { %>
              <tr><td colspan="8">No hay choferes registrados.</td></tr>
            <% } else { %>
              <% choferes.forEach(c => { %>
                <tr>
                  <td><strong><%= c.nombre %></strong><br><small><%= c.direccion || '-' %></small></td>
                  <td><%= c.rut %></td>
                  <td><%= c.telefono || '-' %></td>
                  <td><span class="badge"><%= c.zona_nombre || 'Sin zona' %></span></td>
                  <td><%= c.comunas_asignadas || '-' %></td>
                  <td><%= c.vehiculo_patente || c.vehiculo_id || '-' %></td>
                  <td><span class="badge"><%= c.estado || '-' %></span></td>
                  <td>
                    <div class="row-actions">
                      <a href="/choferes/editar/<%= c.id %>" class="btn btn-secondary"><i data-lucide="pencil"></i> Editar</a>
                      <form action="/choferes/eliminar/<%= c.id %>" method="POST" class="inline-form" onsubmit="return confirm('¿Eliminar este chofer?');">
                        <button type="submit" class="btn-danger"><i data-lucide="trash-2"></i> Eliminar</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
