<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Entregas | MasAgua" }) %>

<body>
  <%- include('partials/header') %>

  <main class="container mx-auto px-4 py-10">
    <div class="mb-6">
      <a href="/admin" class="inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 shadow-md transition">
        <i data-lucide="arrow-left"></i> Volver al panel de administracion
      </a>
    </div>

    <section class="max-w-7xl mx-auto bg-white rounded-lg shadow-lg p-8 mb-12">
      <h1 class="text-3xl font-bold mb-2 text-primary">Asignacion de entregas</h1>
      <p class="text-gray-600 mb-8">
        Pedidos pendientes agrupados por la comuna de entrega seleccionada por el cliente.
      </p>

      <% if (!pedidosPorComuna.length) { %>
        <p class="text-center text-gray-600 py-8">No hay pedidos pendientes para asignar.</p>
      <% } else { %>
        <div class="space-y-8">
          <% pedidosPorComuna.forEach(grupo => { %>
            <div class="bg-white rounded-2xl border border-blue-100 p-6 shadow-sm">
              <h2 class="text-xl font-semibold text-primary mb-4">
                <i data-lucide="map-pin"></i> <%= grupo.comuna %>
              </h2>

              <div class="overflow-x-auto">
                <table class="min-w-full">
                  <thead>
                    <tr>
                      <th>Pedido</th>
                      <th>Cliente</th>
                      <th>Direccion</th>
                      <th>Productos</th>
                      <th>Asignacion</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% grupo.pedidos.forEach(pedido => { %>
                      <tr>
                        <td>#<%= pedido.pedido_id %></td>
                        <td>
                          <strong><%= pedido.cliente_nombre %></strong><br>
                          <small><%= pedido.telefono || '-' %></small>
                        </td>
                        <td><%= pedido.direccion_entrega || '-' %></td>
                        <td>
                          <ul>
                            <% pedido.productos.forEach(producto => { %>
                              <li><%= producto.nombre %> (x<%= producto.cantidad %>)</li>
                            <% }) %>
                          </ul>
                        </td>
                        <td>
                          <% if (!pedido.choferes_disponibles.length) { %>
                            <span class="badge">Sin chofer compatible</span>
                          <% } else { %>
                            <form action="/admin/rutas" method="POST" class="space-y-3">
                              <input type="hidden" name="pedido_id" value="<%= pedido.pedido_id %>">
                              <select name="chofer_id" required>
                                <option value="">Seleccionar</option>
                                <% pedido.choferes_disponibles.forEach(chofer => { %>
                                  <option value="<%= chofer.id %>">
                                    <%= chofer.nombre %><%= chofer.zona ? ` - ${chofer.zona}` : '' %><%= chofer.telefono ? ` (${chofer.telefono})` : '' %>
                                  </option>
                                <% }) %>
                              </select>
                              <input type="datetime-local" name="fecha_programada" required>
                              <button type="submit">Asignar</button>
                            </form>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="max-w-7xl mx-auto bg-white rounded-lg shadow p-6">
      <h2 class="text-2xl font-semibold mb-4 text-primary">
        <i data-lucide="truck"></i> Entregas asignadas
      </h2>

      <% if (!entregas.length) { %>
        <p class="text-center text-gray-600 py-8">No hay entregas asignadas.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr>
                <th>ID</th>
                <th>Pedido</th>
                <th>Cliente</th>
                <th>Comuna</th>
                <th>Chofer</th>
                <th>Zona</th>
                <th>Fecha programada</th>
                <th>Estado</th>
                <th>Productos</th>
              </tr>
            </thead>
            <tbody>
              <% entregas.forEach(entrega => { %>
                <tr>
                  <td>#<%= entrega.id %></td>
                  <td>#<%= entrega.pedido_id %></td>
                  <td><%= entrega.cliente_nombre %></td>
                  <td><%= entrega.comuna_nombre || 'Sin comuna' %></td>
                  <td><%= entrega.chofer_nombre %></td>
                  <td><span class="badge"><%= entrega.chofer_zona_nombre || '-' %></span></td>
                  <td>
                    <%= entrega.fecha_programada ? new Date(entrega.fecha_programada).toLocaleString('es-CL') : '-' %>
                  </td>
                  <td><span class="badge"><%= entrega.estado %></span></td>
                  <td>
                    <ul>
                      <% entrega.productos.forEach(producto => { %>
                        <li><%= producto.nombre %> (x<%= producto.cantidad %>)</li>
                      <% }) %>
                    </ul>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>

