<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Panel Admin | MasAgua" }) %>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <% const stats = metricas || {}; %>
    <% const accesos = [
      { href: '/admin/pedidos', icon: 'clipboard-list', title: 'Pedidos', text: 'Revisar estados y detalle de compras de clientes.', action: 'Ver pedidos' },
      { href: '/admin/rutas', icon: 'map-pinned', title: 'Entregas', text: 'Asignar pedidos pendientes a choferes por comuna.', action: 'Asignar rutas' },
      { href: '/admin/planes', icon: 'badge-check', title: 'Planes', text: 'Aprobar o revisar planes contratados por empresas.', action: 'Ver planes' },
      { href: '/choferes', icon: 'users-round', title: 'Choferes', text: 'Mantener choferes y sus comunas de cobertura.', action: 'Gestionar' },
      { href: '/flota', icon: 'truck', title: 'Flota', text: 'Administrar vehiculos disponibles para reparto.', action: 'Gestionar' }
    ]; %>
    <% const resumen = [
      { label: 'Usuarios', value: stats.usuarios || 0, icon: 'users' },
      { label: 'Pedidos pendientes', value: stats.pedidosPendientes || 0, icon: 'package-clock' },
      { label: 'Entregas asignadas', value: stats.entregasAsignadas || 0, icon: 'route' },
      { label: 'Planes pendientes', value: stats.planesPendientes || 0, icon: 'file-clock' },
      { label: 'Choferes activos', value: stats.choferesActivos || 0, icon: 'id-card' },
      { label: 'Vehiculos', value: stats.vehiculos || 0, icon: 'truck' }
    ]; %>

    <section class="admin-hero">
      <div>
        <p class="section-label">Panel administrativo</p>
        <h1>Hola, <%= user.nombre || 'administrador/a' %></h1>
        <p class="muted">Resumen operativo para demostrar el flujo completo: clientes, pedidos, planes, choferes, flota y asignacion de entregas.</p>
      </div>
      <a href="/admin/rutas" class="btn"><i data-lucide="map-pinned"></i> Asignar entregas</a>
    </section>

    <section class="metric-grid admin-metrics" aria-label="Resumen administrativo">
      <% resumen.forEach(item => { %>
        <article class="metric">
          <span class="icon-pill"><i data-lucide="<%= item.icon %>"></i></span>
          <strong><%= item.value %></strong>
          <span><%= item.label %></span>
        </article>
      <% }) %>
    </section>

    <section class="admin-layout">
      <div>
        <div class="section-heading">
          <p class="section-label">Accesos rapidos</p>
          <h2>Gestion principal</h2>
        </div>
        <div class="app-grid">
          <% accesos.forEach(item => { %>
            <a href="<%= item.href %>" class="app-card admin-action-card">
              <span class="icon-pill"><i data-lucide="<%= item.icon %>"></i></span>
              <h3><%= item.title %></h3>
              <p><%= item.text %></p>
              <span class="card-link"><%= item.action %></span>
            </a>
          <% }) %>
        </div>
      </div>

      <aside class="app-card admin-demo-card">
        <p class="section-label">Administracion</p>
        <h2>Consultas</h2>
        <div class="admin-secondary-links">
          <a href="/admin/clientes"><i data-lucide="contact-round"></i> Clientes</a>
          <a href="/admin/reportes"><i data-lucide="chart-column"></i> Reportes</a>
        </div>
      </aside>
      <aside class="app-card admin-demo-card">
        <p class="section-label">Demo sugerida</p>
        <h2>Flujo para presentar</h2>
        <ol>
          <li>Registrar o usar un cliente demo.</li>
          <li>Crear un pedido con direccion y comuna.</li>
          <li>Entrar a entregas y asignar un chofer compatible.</li>
          <li>Mostrar que el pedido cambia a asignado.</li>
        </ol>
      </aside>
    </section>

    <section class="admin-tables">
      <article>
        <div class="section-heading">
          <p class="section-label">Actividad</p>
          <h2>Pedidos recientes</h2>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Comuna</th>
                <th>Estado</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody>
              <% if (!pedidosRecientes || pedidosRecientes.length === 0) { %>
                <tr><td colspan="5">No hay pedidos registrados.</td></tr>
              <% } else { %>
                <% pedidosRecientes.forEach(pedido => { %>
                  <tr>
                    <td>#<%= pedido.id %></td>
                    <td><%= pedido.cliente_nombre %></td>
                    <td><%= pedido.comuna_nombre || 'Sin comuna' %></td>
                    <td><span class="badge"><%= pedido.estado %></span></td>
                    <td><%= pedido.fecha ? new Date(pedido.fecha).toLocaleDateString('es-CL') : '-' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </article>

      <article>
        <div class="section-heading">
          <p class="section-label">Despacho</p>
          <h2>Entregas recientes</h2>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Pedido</th>
                <th>Chofer</th>
                <th>Estado</th>
                <th>Programada</th>
              </tr>
            </thead>
            <tbody>
              <% if (!entregasRecientes || entregasRecientes.length === 0) { %>
                <tr><td colspan="5">No hay entregas asignadas.</td></tr>
              <% } else { %>
                <% entregasRecientes.forEach(entrega => { %>
                  <tr>
                    <td>#<%= entrega.id %></td>
                    <td>#<%= entrega.pedido_id %></td>
                    <td><%= entrega.chofer_nombre %></td>
                    <td><span class="badge"><%= entrega.estado %></span></td>
                    <td><%= entrega.fecha_programada ? new Date(entrega.fecha_programada).toLocaleString('es-CL') : '-' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </article>
    </section>

    <section>
      <div class="section-heading">
        <p class="section-label">Usuarios</p>
        <h2>Ultimos usuarios registrados</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Rol</th>
            </tr>
          </thead>
          <tbody>
            <% if (!usuarios || usuarios.length === 0) { %>
              <tr><td colspan="4">No hay usuarios registrados.</td></tr>
            <% } else { %>
              <% usuarios.forEach(usuario => { %>
                <tr>
                  <td>#<%= usuario.id %></td>
                  <td><%= usuario.nombre || '-' %></td>
                  <td><%= usuario.email %></td>
                  <td><span class="badge"><%= usuario.rol %></span></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>

