<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Panel Empresa - MasAgua" }) %>
<body>
  <%- include('partials/header') %>

  

  <main class="container mx-auto flex-grow px-4 py-10">

    <p class="text-center text-primaryLight text-xl font-semibold mb-4">
      Bienvenido/a, <%= user.nombre %>
    </p>

    <h2 class="text-2xl font-bold text-center text-primaryLight mb-6">Bienvenido/a al Panel de Empresa</h2>

    <div class="grid gap-8 grid-cols-1 sm:grid-cols-2 md:grid-cols-3">

      <!-- Ver Planes -->
      <a href="/empresa/planes" class="bg-white shadow-lg rounded-2xl p-6 text-center group hover:shadow-xl transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primaryLight mb-4 group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h4l3 8 4-16 3 8h4" />
        </svg>
        <h3 class="text-lg font-semibold text-primary mb-2">Ver Planes</h3>
        <p class="text-sm text-gray-600">Selecciona y contrata un plan para tu empresa.</p>
      </a>

      <!-- Ver Planes Contratados -->
      <a href="/empresa/mis-planes" class="bg-white shadow-lg rounded-2xl p-6 text-center group hover:shadow-xl transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primaryLight mb-4 group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-lg font-semibold text-primary mb-2">Mis Planes</h3>
        <p class="text-sm text-gray-600">Revisa tus planes contratados y su estado.</p>
      </a>

      <!-- Perfil -->
      <a href="/empresa/perfil" class="bg-white shadow-lg rounded-2xl p-6 text-center group hover:shadow-xl transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primaryLight mb-4 group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A4 4 0 117.9 15m3.2 0a4 4 0 115.85 2.804M17 9a4 4 0 10-4-4 4 4 0 004 4z" />
        </svg>
        <h3 class="text-lg font-semibold text-primary mb-2">Mi Perfil</h3>
        <p class="text-sm text-gray-600">Edita tu información personal.</p>
      </a>

    </div>
  </main>

  

  <%- include('partials/footer') %>
</body>
</html>
