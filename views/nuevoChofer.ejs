<!DOCTYPE html>
<html lang="es">
<%- include('partials/head', { title: "Nuevo Chofer | MasAgua" }) %>
<body>
  <%- include('partials/header') %>

  <main class="page-shell">
    <section class="admin-hero">
      <div>
        <p class="section-label">Logistica</p>
        <h1>Agregar chofer</h1>
        <p class="muted">Define una zona base y selecciona solo comunas dentro de esa zona.</p>
      </div>
      <a href="/choferes" class="btn btn-secondary"><i data-lucide="arrow-left"></i> Volver</a>
    </section>

    <section class="driver-form-shell">
      <article class="app-card fleet-form-card">
        <form action="/choferes/nuevo" method="POST" class="fleet-form">
          <div class="form-grid">
            <label>Nombre completo<input type="text" name="nombre" required autocomplete="off"></label>
            <label>RUT<input type="text" name="rut" required autocomplete="off"></label>
            <label>Telefono<input type="text" name="telefono" autocomplete="off"></label>
            <label>Direccion<input type="text" name="direccion" autocomplete="off"></label>
            <label>Estado<input type="text" name="estado" value="activo" autocomplete="off"></label>
            <label>Vehiculo
              <select name="vehiculo_id">
                <option value="">Sin vehiculo asignado</option>
                <% vehiculos.forEach(v => { %>
                  <option value="<%= v.id %>"><%= v.patente %> - <%= v.marca || '' %> <%= v.modelo || '' %></option>
                <% }) %>
              </select>
            </label>
            <label>Zona base
              <select name="zona_id" required data-zone-select>
                <option value="">Selecciona una zona</option>
                <% zonas.forEach(z => { %>
                  <option value="<%= z.id %>"><%= z.nombre %></option>
                <% }) %>
              </select>
            </label>
            <label>Comunas de cobertura
              <select name="comunas" multiple required size="9" data-commune-select>
                <% zonas.forEach(z => { %>
                  <% z.comunas.forEach(c => { %>
                    <option value="<%= c.id %>" data-zona="<%= z.id %>"><%= c.nombre %></option>
                  <% }) %>
                <% }) %>
              </select>
            </label>
          </div>

          <p class="muted form-note">Las comunas disponibles cambian segun la zona base. Esto evita rutas ilogicas entre sectores lejanos.</p>

          <div class="form-actions">
            <button type="submit"><i data-lucide="save"></i> Guardar chofer</button>
            <a href="/choferes" class="btn btn-secondary">Cancelar</a>
          </div>
        </form>
      </article>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script>
  document.addEventListener('DOMContentLoaded', function () {
    const zonaSelect = document.querySelector('[data-zone-select]');
    const comunaSelect = document.querySelector('[data-commune-select]');
    if (!zonaSelect || !comunaSelect) return;

    function syncComunas() {
      const zonaId = zonaSelect.value;
      Array.from(comunaSelect.options).forEach(option => {
        const visible = option.dataset.zona === zonaId;
        option.hidden = !visible;
        option.disabled = !visible;
        if (!visible) option.selected = false;
      });
    }

    zonaSelect.addEventListener('change', syncComunas);
    syncComunas();
  });
</script>
</body>
</html>
